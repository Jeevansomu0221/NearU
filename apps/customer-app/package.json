{
  "name": "customer-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "fix:expo": "npx expo install --fix",
    "prebuild:android:clean": "npx expo prebuild --platform android --clean",
    "build:android:development": "npx eas-cli build -p android --profile development",
    "build:android": "npx eas-cli build -p android --profile production",
    "build:android:local": "npx eas-cli build -p android --profile production --local",
    "submit:android": "npx eas-cli submit -p android --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "^24.0.0",
    "@react-native-firebase/messaging": "24.0.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.10.1",
    "@react-navigation/stack": "^7.6.16",
    "axios": "^1.13.4",
    "expo": "~54.0.35",
    "expo-dev-client": "~6.0.21",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-razorpay": "^2.3.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/react": "~19.1.0",
    "@types/react-navigation": "^3.0.8",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-razorpay",
          "react-native-vector-icons"
        ]
      }
    }
  },
  "private": true
}
