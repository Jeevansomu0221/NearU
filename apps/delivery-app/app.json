{
  "expo": {
    "name": "Vyaha Delivery",
    "slug": "vyaha-delivery",
    "scheme": "vyaha-delivery",
    "version": "1.0.13",
    "orientation": "portrait",
    "icon": "./assets/vyaha-delivery-app-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.vyaha.delivery",
      "versionCode": 27,
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/vyaha-delivery-adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "blockedPermissions": [
        "android.permission.READ_PHONE_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging",
      "@react-native-firebase/crashlytics",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      "../../plugins/with-vyaha-gradle-config",
      "../../plugins/with-vyaha-android-proguard",
      [
        "../../plugins/with-vyaha-android-notifications",
        {
          "iconSource": "./assets/vyaha-delivery-app-icon.png",
          "color": "#0F9D58",
          "channelName": "Vyaha Delivery alerts",
          "channelDescription": "Important delivery job and profile alerts."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Vyaha Delivery uses your location while you are working to show nearby jobs, calculate distance, and update delivery progress."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Vyaha Delivery needs photo access so you can upload identity, vehicle, and bank verification documents."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5c93a2d3-d4bd-4df7-90ba-a0565eb94ccb"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5c93a2d3-d4bd-4df7-90ba-a0565eb94ccb",
      "fallbackToCacheTimeout": 0,
      "enabled": true
    },
    "owner": "jeevansomu"
  }
}
