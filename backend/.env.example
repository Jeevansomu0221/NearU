NODE_ENV=production
PORT=5000
API_BASE_URL=https://vyaha-app-backend.onrender.com
CORS_ORIGINS=https://your-admin-domain.example
REQUEST_BODY_LIMIT=5mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

MONGODB_URI=
JWT_SECRET=
JWT_EXPIRY=15m
REFRESH_JWT_EXPIRY=7d

ADMIN_PANEL_PHONE=
ADMIN_PANEL_PASSWORD=

OTP_PROVIDER=2factor
OTP_FIREBASE_FALLBACK=true
TWOFACTOR_API_KEY=
# Optional: free trial key for voice-call OTP testing (set TWOFACTOR_OTP_CHANNEL=voice)
TWOFACTOR_VOICE_API_KEY=
TWOFACTOR_SENDER_ID=VYAHA
TWOFACTOR_TEMPLATE_NAME=Vyaha_OTP_Login
TWOFACTOR_DLT_ENTITY_ID=
# sms = production DLT SMS (main API key). voice = dev/test phone-call OTP (voice API key).
TWOFACTOR_OTP_CHANNEL=sms

FIREBASE_PROJECT_ID=vyaha-a24a7
FIREBASE_SERVICE_ACCOUNT_JSON=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=nearu-app

GOOGLE_MAPS_API_KEY=
DELIVERY_RADIUS_KM=8
DELIVERY_LOCATION_FRESHNESS_MINUTES=10
