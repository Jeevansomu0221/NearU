NODE_ENV=production
PORT=5000
API_BASE_URL=https://vyaha-app-backend.onrender.com
CORS_ORIGINS=https://your-admin-domain.example,https://www.vyaha.com,https://vyaha.com,http://localhost:5173,http://localhost:5174,http://localhost:5175
REQUEST_BODY_LIMIT=5mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

MONGODB_URI=
JWT_SECRET=
JWT_EXPIRY=15m
REFRESH_JWT_EXPIRY=7d

ADMIN_PANEL_PHONE=
ADMIN_PANEL_PASSWORD=

OTP_PROVIDER=2factor
OTP_FIREBASE_FALLBACK=true
OTP_DEBUG=true

TWOFACTOR_API_KEY=
TWOFACTOR_SENDER_ID=VYAHA
TWOFACTOR_TEMPLATE_NAME=Vyaha_OTP_Login
TWOFACTOR_DLT_ENTITY_ID=1201178135264753827

FIREBASE_PROJECT_ID=vyaha-a24a7
FIREBASE_SERVICE_ACCOUNT_JSON=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional fallback when Razorpay QR/links are unavailable — customer pays platform VPA directly
PLATFORM_UPI_VPA=
PLATFORM_UPI_PAYEE_NAME=Vyaha
RAZORPAY_WEBHOOK_SECRET=

CLOUDINARY_CLOUD_NAME=
